{
  "name": "hrms-local",
  "version": "1.0.0",
  "description": "Local-only HRMS built for offline use with Node.js, Express, and Prisma.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node seed.js",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^5.10.2"
  },
  "private": true
}
